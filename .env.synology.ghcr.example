# Copy this file to .env.synology.ghcr for the Synology GHCR deployment target.
#
# GHCR_IMAGE is used by Compose interpolation. If Synology Container Manager does not
# substitute it from this file in your setup, edit the "image:" line directly in
# compose.synology.ghcr.yml with the same value.

GHCR_IMAGE=ghcr.io/elastic21/capsuleai-synology-mcp-gateway:latest

NODE_ENV=production
CG_ENVIRONMENT=prod
LOG_LEVEL=info

POSTGRES_DB=cg_gateway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-now
DATABASE_URL=postgres://postgres:change-me-now@postgres:5432/cg_gateway

MCP_TRANSPORT=http
PORT=8787
HOST=0.0.0.0
MIGRATE_ON_BOOT=true
MIGRATE_MAX_ATTEMPTS=30
MIGRATE_RETRY_DELAY_MS=3000

MCP_AUTH_MODE=none
MCP_BEARER_TOKENS=
MCP_REQUIRED_SCOPES=mcp:tools
MCP_AUTHORIZATION_SERVER_ISSUER=
MCP_RESOURCE_NAME=Cybergogne MCP Gateway

ATLASSIAN_BASE_URL=https://your-tenant.atlassian.net
ATLASSIAN_AUTH_MODE=basic
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_BEARER_TOKEN=

DEFAULT_WIDGET_ACTOR_REF=widget-user@synology
DEV_APPROVAL_BYPASS=false
