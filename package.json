{
  "name": "cybergogne-gateway-mcp",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @cybergogne/mcp-server dev",
    "start:prod": "node apps/mcp-server/dist/index.js",
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "typecheck": "pnpm -r --workspace-concurrency=1 run typecheck",
    "lint": "pnpm -r --workspace-concurrency=1 run lint",
    "test": "vitest run --passWithNoTests",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:prod": "node scripts/migrate-prod.mjs",
    "seed:registry": "tsx scripts/seed-registry.ts",
    "seed:registry:prod": "node scripts/seed-registry-prod.mjs",
    "export:registry": "tsx scripts/export-registry.ts",
    "bootstrap:discover": "tsx scripts/bootstrap-discover.ts",
    "bootstrap:validate": "tsx scripts/bootstrap-validate.ts",
    "bootstrap:apply": "tsx scripts/bootstrap-apply.ts",
    "bootstrap:report": "tsx scripts/bootstrap-report.ts"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "globals": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest",
    "yaml": "latest"
  }
}
